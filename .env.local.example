NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# BallDontLie NBA stats API — https://www.balldontlie.io/
# Required for live player stat sync (/api/stats/sync)
# Free tier: 5 req/min (set BDL_SEARCH_DELAY_MS=12000)
# All-Star ($9.99/mo): 60 req/min (default BDL_SEARCH_DELAY_MS=500 is fine)
BALLDONTLIE_API_KEY=your_balldontlie_api_key
BDL_SEARCH_DELAY_MS=500
NEXT_PUBLIC_APP_URL=http://localhost:3000
